# Ambiente: local | preview | production
APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Valores publicos necessarios ao cliente Supabase Admin Auth. Nao concedem service role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY - nunca prefixar com NEXT_PUBLIC_, registrar ou enviar ao navegador.
SUPABASE_SERVICE_ROLE_KEY=
OTP_PEPPER=replace-with-at-least-32-random-characters
GUARDIAN_SESSION_HOURS=8
RESEND_API_KEY=
EMAIL_FROM=Cubo Viagens <viagens@example.cubo.global>

# Local reproduzivel, sem credenciais externas.
DEMO_MODE=true
DEMO_ADMIN_EMAIL=admin@example.cubo.global

