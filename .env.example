# Ambiente: local | preview | production
APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chave publica usada pelo fluxo OAuth do Supabase. Nao concede service role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SERVER ONLY - nunca prefixar com NEXT_PUBLIC_, registrar ou enviar ao navegador.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
GUARDIAN_SESSION_SECRET=replace-with-a-different-32-character-secret
ADMIN_SESSION_SECRET=replace-with-another-32-character-secret
GUARDIAN_SESSION_DAYS=30
ADMIN_SESSION_HOURS=12

# Local reproduzivel, sem credenciais externas.
DEMO_MODE=true
DEMO_ADMIN_EMAIL=admin@example.cubo.global
DEMO_ADMIN_PASSWORD=

